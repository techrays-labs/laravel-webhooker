{
    "name": "techrays-labs/laravel-webhooker",
    "description": "A Laravel-native Webhook Reliability Engine for outbound & inbound webhook management with retry, replay, and dashboard.",
    "version": "0.1.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "webhooks",
        "webhook-engine",
        "outbound-webhooks",
        "inbound-webhooks",
        "retry",
        "replay",
        "hmac",
        "queue"
    ],
    "authors": [
        {
            "name": "TechRays Labs",
            "email": "hello@techrays.io"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/view": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "TechRaysLabs\\Webhooker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TechRaysLabs\\Webhooker\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TechRaysLabs\\Webhooker\\WebhookerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
